SITE_URL=https://myhalalstore.com

# ── GOOGLE APPS SCRIPT ──
# Get after deploying apps-script.js as a Web App
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXXXX/exec
